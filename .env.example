# =============================================================================
# Blooprint — Variables d'environnement (Monorepo)
# Copier vers .env et remplir les valeurs
# NE JAMAIS committer .env dans Git
# =============================================================================

# -----------------------------------------------------------------------------
# Database PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_DB=blooprint
POSTGRES_USER=blooprint
POSTGRES_PASSWORD=secret
POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# Backend Laravel
# -----------------------------------------------------------------------------
APP_KEY=
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# Sanctum — expiration des tokens en minutes (default: 365 jours)
SANCTUM_TOKEN_EXPIRATION=525600

# -----------------------------------------------------------------------------
# Frontend Next.js
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost/api/v1

# Supabase (Auth + Storage — phase de transition)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Stripe (clé publique uniquement côté frontend)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key

# -----------------------------------------------------------------------------
# Stripe (Backend uniquement — ne pas préfixer NEXT_PUBLIC_)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret
STRIPE_PRICE_MONTHLY_ID=price_xxxxx
STRIPE_PRICE_YEARLY_ID=price_xxxxx

# -----------------------------------------------------------------------------
# Resend (emails transactionnels)
# -----------------------------------------------------------------------------
RESEND_API_KEY=your_resend_api_key

# -----------------------------------------------------------------------------
# Seeder — compte admin par défaut (ne pas mettre de vraies infos ici)
# -----------------------------------------------------------------------------
ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_NAME=Admin
ADMIN_SEED_USERNAME=admin
